{
  "name": "acc-telemetry-engineer",
  "version": "1.0.0",
  "description": "Cross-platform race-engineer telemetry app for Assetto Corsa Competizione",
  "author": "ACC Telemetry Engineer",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:all": "electron-vite build && electron-builder -mw",
    "release": "electron-vite build && electron-builder --win --publish always",
    "relay": "node relay-server.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.408.0",
    "recharts": "^2.12.7",
    "ws": "^8.18.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4"
  }
}
